#!/bin/bash

# Requirements
n_tasks=1
n_cpus=1
mem="4G"
task_file=$HOME/microphone/microphone.disbatch

# Load FI modules and source virtualenv
module purge
module load disBatch/2.0
module load python/3.8.12
source $HOME/Documents/PYTHON/envs/ibllib/bin/activate
# Submit the slurm job, run ntasks at a time, each with n_pus cores
sbatch --partition=gen -n $n_tasks -c $n_cpus disBatch $task_file
