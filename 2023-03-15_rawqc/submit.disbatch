#!/bin/bash

# Requirements
n_tasks=1
n_cpus=2
mem=16G
task_file=$HOME/Documents/PYTHON/sdsc-slurms/2023-03-15_rawqc/rawqc.disbatch

# Load FI modules and source virtualenv
module purge
module load disBatch
module load fftw/3.3.10
module load python/3.8.12
source $HOME/Documents/PYTHON/envs/ibllib/bin/activate
# Submit the slurm job, run ntasks at a time, each with n_pus cores
sbatch -o slurm.%j.out --partition=gen --ntasks=$n_tasks --cpus-per-task=$n_cpus --mem=$mem disBatch $task_file
