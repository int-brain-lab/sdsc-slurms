#!/bin/bash

# Requirements
task_file=/mnt/home/owinter/sdsc-slurms/pykilosort/pykilosort.disbatch

# Load FI modules and source virtualenv
module purge
module load python/3.8.12
module load cuda/11.4.4
module load fftw/3.3.10
module load disBatch/2.0
source /mnt/home/owinter/Documents/PYTHON/envs/pykilosort/bin/activate

sbatch --partition=gpu disBatch $task_file
